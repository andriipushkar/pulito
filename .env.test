# ============================================
# Test Environment — for CI and automated tests
# ============================================

NODE_ENV=test
PORT=3001
APP_URL=http://localhost:3001

# --- Database (test-specific, isolated from dev) ---
DATABASE_URL=postgresql://clean_user:clean_pass@localhost:5432/clean_shop_test?schema=public
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5

# --- Redis (separate DB index for tests) ---
REDIS_URL=redis://localhost:6380/1

# --- JWT ---
JWT_SECRET=test-jwt-secret-do-not-use-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ALGORITHM=HS256

# --- Email (disabled in tests) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@localhost
SMTP_PASS=test
SMTP_FROM=noreply@test.localhost

# --- Typesense ---
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=test-typesense-key
TYPESENSE_PROTOCOL=http

# --- Files ---
UPLOAD_DIR=./uploads-test
MAX_FILE_SIZE=10485760

# --- Watermark (disabled in tests) ---
WATERMARK_ENABLED=false
WATERMARK_TEXT=test

# --- Monitoring (disabled in tests) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=error

# --- Security ---
APP_SECRET=test-app-secret-do-not-use-in-production-min32
MAINTENANCE_MODE=false

# --- Push (disabled) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:test@localhost

# --- External services (all disabled/mocked in tests) ---
TELEGRAM_BOT_TOKEN=
VIBER_BOT_TOKEN=
NOVA_POSHTA_API_KEY=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
MONOBANK_TOKEN=
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_PIXEL_ID=
FACEBOOK_CAPI_TOKEN=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
AXIOM_TOKEN=
AXIOM_DATASET=clean-shop-test
