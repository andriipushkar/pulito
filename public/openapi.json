                      ]
                    }
                  },
                  "freeDeliveryThreshold": {
                    "default": 0,
                    "type": "number",
                    "minimum": 0
                  },
                  "estimatedDays": {
                    "default": "3-5",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Оновлено"
