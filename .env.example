# ============================================
# Pulito — ENV Config
# ============================================

# --- Середовище ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- База даних PostgreSQL ---
DATABASE_URL=postgresql://pulito_user:pulito_pass@localhost:5432/pulito_trade?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- JWT авторизація ---
# ОБОВ'ЯЗКОВО згенеруйте новий: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth (опціонально) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@shop.example.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_MANAGER_CHAT_ID=

# --- Viber ---
VIBER_BOT_TOKEN=

# --- Instagram ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Facebook ---
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# --- Нова Пошта ---
NOVA_POSHTA_API_KEY=

# --- Укрпошта ---
UKRPOSHTA_BEARER_TOKEN=

# --- Оплата (LiqPay) ---
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# --- Оплата (Monobank) ---
MONOBANK_TOKEN=

# --- Оплата (WayForPay) ---
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=

# --- Typesense (повнотекстовий пошук) ---
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=ts-pulito-dev-key  # ЗМІНИТИ для production: openssl rand -hex 32
TYPESENSE_PROTOCOL=http              # https для production

# --- Файли ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760               # 10MB, максимальний розмір завантажуваного файлу

# --- Водяний знак на зображеннях ---
# ⚙️ Тепер налаштовується в /admin → Налаштування → Система. ENV = лише fallback.
WATERMARK_TEXT=pulito.trade              # Текст водяного знака
WATERMARK_ENABLED=true                # false щоб вимкнути

# --- Видалення фону на фото товарів (опціонально) ---
# ⚙️ Тепер налаштовується в /admin → Налаштування → Система. ENV = лише fallback.
REMOVEBG_API_KEY=                     # https://www.remove.bg/api — без ключа функція вимкнена

# --- Моніторинг ---
SENTRY_DSN=                           # https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=               # Той самий DSN для клієнтської сторони
SENTRY_ENVIRONMENT=production
SENTRY_CSP_REPORT_URI=                # CSP violation reporting: https://xxx.ingest.sentry.io/api/xxx/security/?sentry_key=xxx
# ⚙️ LOG_LEVEL тепер налаштовується в /admin → Налаштування → Система (застосовується одразу). ENV = початкове значення на старті.
LOG_LEVEL=info                        # debug | info | warn | error

# --- Обмеження доступу до адмінки за IP (опціонально) ---
# ⚙️ Тепер налаштовується в /admin → Налаштування → Система. ENV = лише fallback.
# ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8   # Залиште порожнім або закоментуйте щоб вимкнути

# --- Режим обслуговування ---
# ⚙️ Вмикається/вимикається в /admin → Режим обслуговування (зберігається в БД). ENV=true = примусовий override.
MAINTENANCE_MODE=false

# --- Push Notifications (VAPID) ---
# Ключі лишаються тут (криптоматеріал). ⚙️ VAPID_EMAIL налаштовується в /admin → Налаштування → Система.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@pulito.trade

# --- App Secret (CSRF, підпис) ---
APP_SECRET=  # REQUIRED: min 32 chars, generate with: openssl rand -hex 32

# --- JWT Algorithm (HS256 or RS256) ---
# For RS256: generate keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=  # ./private.pem (RS256 only)
JWT_PUBLIC_KEY_PATH=   # ./public.pem (RS256 only)

# --- AI: генератори описів та SEO ---
# Claude (Anthropic) — найкраща якість, дорого (~$0.02/генерація)
ANTHROPIC_API_KEY=            # https://console.anthropic.com
# Gemini (Google) — дешева альтернатива (~$0.0005/генерація з gemini-1.5-flash)
GEMINI_API_KEY=               # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash # опціонально; інші: gemini-2.5-flash-lite (найдешевша), gemini-2.5-pro, gemini-2.0-flash

# --- Server-Side Tracking ---
FACEBOOK_PIXEL_ID=
FACEBOOK_CAPI_TOKEN=  # Facebook Conversion API token (from Events Manager)
GA4_MEASUREMENT_ID=   # G-XXXXXXXXXX
GA4_API_SECRET=       # From GA4 Admin > Data Streams > Measurement Protocol

# --- Client-Side Analytics (loaded via lazyOnload — won't block page render) ---
NEXT_PUBLIC_GA4_ID=           # G-XXXXXXXXXX (for gtag.js on client)
NEXT_PUBLIC_FB_PIXEL_ID=      # Facebook Pixel ID (for fbevents.js on client)

# --- Cloudflare R2 Storage (offload images from VPS to CDN) ---
R2_ACCOUNT_ID=                # Cloudflare account ID
R2_ACCESS_KEY_ID=             # R2 API token access key
R2_SECRET_ACCESS_KEY=         # R2 API token secret
R2_BUCKET=                    # Bucket name (e.g. "pulito-media")
R2_PUBLIC_URL=                # Public URL (e.g. https://media.pulito.trade)

# --- Cloud Logging (Axiom — free 500MB/month) ---
AXIOM_TOKEN=                  # Axiom API token
AXIOM_DATASET=pulito          # Dataset name in Axiom

# --- Secrets Management ---
# For production teams, consider using:
# - Infisical (https://infisical.com) — open-source secrets management
# - HashiCorp Vault — enterprise secrets management
# - AWS Secrets Manager / Azure Key Vault — cloud-native
