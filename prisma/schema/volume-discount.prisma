// ─────────────────────────────────────
// Volume Discounts (Знижки за обсяг)
// ─────────────────────────────────────
enum DiscountType {
  percentage
  fixed_amount
}

model VolumeDiscount {
  id              Int          @id @default(autoincrement())
  productId       Int?         @map("product_id")
  product         Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId      Int?         @map("category_id")
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  minQuantity     Int          @map("min_quantity")
  maxQuantity     Int?         @map("max_quantity")
  // Decimal(5,2) so percent values stay exact (12.5% → 12.50, not
  // 12.49999… in Float-land). Matches billing.prisma and orders — every
  // money-touching number stays in Decimal.
  discountPercent Decimal      @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountType    DiscountType @default(percentage) @map("discount_type")
  isActive        Boolean      @default(true) @map("is_active")
  priority        Int          @default(0)
  startsAt        DateTime?    @map("starts_at")
  endsAt          DateTime?    @map("ends_at")
  // Stacking control — which other discount types can combine with this one.
  // Values: "personal_price", "coupon", "loyalty". Empty/null = stacks with
  // nothing (won't combine with anything else). Cart logic in services/cart.ts
  // honours the intersection of every applied discount's `stackableWith`.
  stackableWith   String[]     @default([]) @map("stackable_with")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("volume_discounts")
}
