// ─────────────────────────────────────
// Campaign Rules (RFM-based email campaigns)
// ─────────────────────────────────────
enum CampaignFrequency {
  once
  weekly
  biweekly
  monthly
}

model CampaignRule {
  id              Int               @id @default(autoincrement())
  name            String
  rfmSegment      String            @map("rfm_segment")
  emailTemplateId Int               @map("email_template_id")
  emailTemplate   EmailTemplate     @relation(fields: [emailTemplateId], references: [id])
  frequency       CampaignFrequency @default(once)
  isActive        Boolean           @default(true) @map("is_active")
  lastRunAt       DateTime?         @map("last_run_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  logs            CampaignLog[]

  @@map("campaign_rules")
}

model CampaignLog {
  id                Int          @id @default(autoincrement())
  ruleId            Int          @map("rule_id")
  rule              CampaignRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId            Int          @map("user_id")
  user              User         @relation(fields: [userId], references: [id])
  sentAt            DateTime     @default(now()) @map("sent_at")
  // Engagement metrics — populated by tracking pixel (openedAt) and click
  // redirect (clickedAt). conversionOrderId set when this campaign drove a
  // subsequent purchase (matched within 7-day attribution window).
  openedAt          DateTime?    @map("opened_at")
  clickedAt         DateTime?    @map("clicked_at")
  convertedAt       DateTime?    @map("converted_at")
  conversionOrderId Int?         @map("conversion_order_id")

  @@unique([ruleId, userId, sentAt])
  @@index([sentAt(sort: Desc)])
  @@index([openedAt])
  @@map("campaign_logs")
}
