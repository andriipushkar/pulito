// ─────────────────────────────────────
// 23.6 Publications
// ─────────────────────────────────────
enum PublicationStatus {
  draft
  scheduled
  published
  failed
}

model Publication {
  id              Int               @id @default(autoincrement())
  title           String
  content         String
  imagePath       String?           @map("image_path")
  productId       Int?              @map("product_id")
  product         Product?          @relation("PublicationProduct", fields: [productId], references: [id])
  categoryId      Int?              @map("category_id")
  category        Category?         @relation("PublicationCategory", fields: [categoryId], references: [id])
  channels        Json
  status          PublicationStatus @default(draft)
  scheduledAt     DateTime?         @map("scheduled_at")
  publishedAt     DateTime?         @map("published_at")
  createdBy       Int               @map("created_by")
  creator         User              @relation(fields: [createdBy], references: [id])
  hashtags        String?
  firstComment    String?           @map("first_comment")
  igMediaId       String?           @map("ig_media_id")
  igPermalink     String?           @map("ig_permalink")
  igInsightsJson  Json?             @map("ig_insights_json")
  tgMessageId     BigInt?           @map("tg_message_id")
  viberMsgToken   String?           @map("viber_message_token")
  fbPostId        String?           @map("fb_post_id")
  fbPermalink     String?           @map("fb_permalink")
  buttons         Json?
  channelContents Json?             @map("channel_contents") // Per-channel content overrides: { telegram: { title, content, hashtags }, ... }
  templateType    String?           @map("template_type")
  errorMessage    String?           @map("error_message")
  retryCount      Int               @default(0) @map("retry_count")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  images         PublicationImage[]
  channelResults PublicationChannel[]

  @@index([status, scheduledAt])
  @@index([createdBy])
  @@index([publishedAt(sort: Desc)])
  @@map("publications")
}

model PublicationChannel {
  id            Int         @id @default(autoincrement())
  publicationId Int         @map("publication_id")
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  channel       String // telegram, viber, facebook, instagram, tiktok, site
  status        String      @default("pending") // pending, published, failed
  externalId    String?     @map("external_id") // tg message_id, ig media_id, fb post_id, etc.
  permalink     String? // link to the post
  errorMessage  String?     @map("error_message")
  retryCount    Int         @default(0) @map("retry_count")
  views         Int? // Number of views/impressions
  clicks        Int? // Number of clicks/interactions
  engagement    Float? // Engagement rate (likes+comments+shares / views)
  publishedAt   DateTime?   @map("published_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([publicationId, channel])
  @@index([publicationId])
  @@map("publication_channels")
}

model PublicationImage {
  id            Int         @id @default(autoincrement())
  publicationId Int         @map("publication_id")
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  imagePath     String      @map("image_path")
  imageUrl      String?     @map("image_url")
  sortOrder     Int         @default(0) @map("sort_order")
  altText       String?     @map("alt_text")
  igMediaId     String?     @map("ig_media_id")
  width         Int?
  height        Int?
  sizeBytes     Int?        @map("size_bytes")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([publicationId, sortOrder])
  @@map("publication_images")
}

// ─────────────────────────────────────
// Marketplace Integrations (Rozetka, Prom.ua)
// ─────────────────────────────────────
model MarketplaceConnection {
  id         Int       @id @default(autoincrement())
  platform   String    @unique // rozetka, prom
  apiKey     String?   @map("api_key")
  apiSecret  String?   @map("api_secret")
  shopId     String?   @map("shop_id")
  isActive   Boolean   @default(false) @map("is_active")
  lastSyncAt DateTime? @map("last_sync_at")
  config     Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  listings MarketplaceListing[]
  returns  MarketplaceReturn[]

  @@map("marketplace_connections")
}

model MarketplaceListing {
  id           Int                   @id @default(autoincrement())
  connectionId Int                   @map("connection_id")
  connection   MarketplaceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  productId    Int                   @map("product_id")
  product      Product               @relation(fields: [productId], references: [id])
  externalId   String?               @map("external_id")
  status       String                @default("draft") // draft, active, paused, error
  externalUrl  String?               @map("external_url")
  lastError    String?               @map("last_error")
  syncedAt     DateTime?             @map("synced_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@unique([connectionId, productId])
  @@index([productId])
  @@map("marketplace_listings")
}

// ─────────────────────────────────────
// Multi-Warehouse (Мульти-склад)
// ─────────────────────────────────────
model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  city      String
  address   String?
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stock WarehouseStock[]

  @@map("warehouses")
}

model WarehouseStock {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([warehouseId, productId])
  @@index([productId])
  @@map("warehouse_stock")
}
