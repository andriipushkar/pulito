// ─────────────────────────────────────
// Subscriptions (Subscribe & Save)
// ─────────────────────────────────────
enum SubscriptionFrequency {
  weekly
  biweekly
  monthly
  bimonthly
}

enum SubscriptionStatus {
  active
  paused
  cancelled
}

enum SubscriptionCancelReason {
  user_requested
  payment_failed
  product_unavailable
  other
}

model Subscription {
  id                  Int                       @id @default(autoincrement())
  userId              Int                       @map("user_id")
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  frequency           SubscriptionFrequency
  status              SubscriptionStatus        @default(active)
  nextDeliveryAt      DateTime                  @map("next_delivery_at")
  discountPercent     Decimal                   @default(5) @map("discount_percent") @db.Decimal(5, 2)
  lastOrderId         Int?                      @map("last_order_id")
  pausedAt            DateTime?                 @map("paused_at")
  pausedReason        String?                   @map("paused_reason")
  cancelledAt         DateTime?                 @map("cancelled_at")
  cancelReason        SubscriptionCancelReason? @map("cancel_reason")
  // Failed-payment retry state. Cron retries up to 2 times before auto-pausing
  // with reason='payment_failed'. Reset on successful payment.
  paymentRetryCount   Int                       @default(0) @map("payment_retry_count")
  lastFailedPaymentAt DateTime?                 @map("last_failed_payment_at")
  // When set, the reminder cron should send a pre-delivery email/SMS
  // (defaults to nextDeliveryAt - 24h on subscription update).
  remindAt            DateTime?                 @map("remind_at")
  reminderSentAt      DateTime?                 @map("reminder_sent_at")
  deliveryMethod      String?                   @map("delivery_method")
  deliveryCity        String?                   @map("delivery_city")
  deliveryAddress     String?                   @map("delivery_address")
  paymentMethod       String?                   @map("payment_method")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  items SubscriptionItem[]

  @@index([userId])
  @@index([status, nextDeliveryAt])
  @@index([status, remindAt])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             Int          @id @default(autoincrement())
  subscriptionId Int          @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  productId      Int          @map("product_id")
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int

  @@unique([subscriptionId, productId])
  @@map("subscription_items")
}
